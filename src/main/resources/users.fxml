<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.UsersController">

    <VBox spacing="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">

        <HBox alignment="CENTER_LEFT">
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Users Management" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleNewUser" style="-fx-background-color: #7c3aed; -fx-text-fill: white;                            -fx-font-size: 14px; -fx-pref-height: 40px;                            -fx-pref-width: 160px; -fx-cursor: hand;                            -fx-background-radius: 8;" text="+ New User" />
        </HBox>

        <HBox spacing="15">
            <VBox alignment="CENTER" prefHeight="90" prefWidth="200" style="-fx-background-color: #1e293b; -fx-background-radius: 10;">
                <Label fx:id="totalUsersLabel" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;" text="0" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;" text="TOTAL USERS" />
            </VBox>
            <VBox alignment="CENTER" prefHeight="90" prefWidth="200" style="-fx-background-color: #1e293b; -fx-background-radius: 10;">
                <Label fx:id="activeUsersLabel" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;" text="0" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;" text="ACTIVE USERS" />
            </VBox>
            <VBox alignment="CENTER" prefHeight="90" prefWidth="200" style="-fx-background-color: #1e293b; -fx-background-radius: 10;">
                <Label fx:id="inactiveUsersLabel" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;" text="0" />
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;" text="INACTIVE USERS" />
            </VBox>
        </HBox>

        <TableView fx:id="usersTable" style="-fx-background-color: #1e293b;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nomCol" prefWidth="170" text="NAME" />
                <TableColumn fx:id="emailCol" prefWidth="240" text="EMAIL" />
                <TableColumn fx:id="roleCol" prefWidth="150" text="ROLES" />
                <TableColumn fx:id="activeCol" prefWidth="100" text="STATUS" />
                <TableColumn fx:id="actionsCol" prefWidth="160" text="ACTIONS" />
            </columns>
        </TableView>

        <Label fx:id="messageLabel" style="-fx-font-size: 13px;" text="" />

    </VBox>
</AnchorPane>
